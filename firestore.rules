rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // FUNCIONES DE UTILIDAD
    // ========================================

    // Verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verificar si el usuario es administrador
    function isAdmin() {
      return isAuthenticated() &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super-admin', 'admin']);
    }

    // Verificar si el usuario es manager o superior
    function isManagerOrHigher() {
      return isAuthenticated() &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super-admin', 'admin', 'manager']);
    }

    // Verificar si el usuario es el propietario del documento o administrador
    function isOwnerOrAdmin(userId) {
      return isAuthenticated() &&
             (request.auth.uid == userId || isAdmin());
    }

    // ========================================
    // COLECCIÓN DE USUARIOS
    // ========================================

    match /users/{userId} {
      // Solo el usuario puede leer su propio perfil
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Solo administradores pueden crear/editar usuarios
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);

      // Solo administradores pueden eliminar usuarios
      allow delete: if isAdmin();
    }

    // ========================================
    // TIPOS DE LICENCIAS (LECTURA PÚBLICA PARA USUARIOS AUTENTICADOS)
    // ========================================

    match /licenseTypes/{document} {
      // Cualquier usuario autenticado puede leer tipos de licencias
      allow read: if isAuthenticated();

      // Solo administradores pueden crear/editar/eliminar tipos de licencias
      allow write: if isAdmin();
    }

    // ========================================
    // EMPLEADOS
    // ========================================

    match /employees/{employeeId} {
      // Managers y superiores pueden leer todos los empleados
      // Empleados pueden leer su propio perfil
      allow read: if isManagerOrHigher() ||
                   (isAuthenticated() && request.auth.uid == resource.data.userId);

      // Solo managers y superiores pueden crear empleados
      allow create: if isManagerOrHigher();

      // Managers y superiores pueden editar empleados
      // Empleados pueden editar su propio perfil básico
      allow update: if isManagerOrHigher() ||
                     (isAuthenticated() && request.auth.uid == resource.data.userId &&
                      // Solo campos básicos, no información sensible
                      request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['firstName', 'lastName', 'phone', 'address', 'emergencyContact']));

      // Solo administradores pueden eliminar empleados
      allow delete: if isAdmin();
    }

    // ========================================
    // SOLICITUDES DE LICENCIAS
    // ========================================

    match /licenseRequests/{requestId} {
      // El empleado puede leer sus propias solicitudes
      // Managers y superiores pueden leer todas las solicitudes
      allow read: if isManagerOrHigher() ||
                   (isAuthenticated() && request.auth.uid == resource.data.employeeId);

      // Empleados pueden crear solicitudes para sí mismos
      // Managers pueden crear solicitudes para otros
      allow create: if isAuthenticated() &&
                     (request.auth.uid == request.resource.data.employeeId || isManagerOrHigher());

      // Empleados pueden actualizar sus propias solicitudes (solo ciertos campos)
      // Managers pueden actualizar cualquier solicitud
      allow update: if isManagerOrHigher() ||
                     (isAuthenticated() && request.auth.uid == resource.data.employeeId &&
                      // Solo campos permitidos para empleados
                      request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['reason', 'observations', 'startDate', 'endDate', 'quantity']));

      // Solo managers pueden eliminar solicitudes
      allow delete: if isManagerOrHigher();
    }

    // ========================================
    // COLECCIONES ADICIONALES (SI EXISTEN)
    // ========================================

    // Configuraciones del sistema
    match /system/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Logs de auditoría
    match /audit/{document} {
      allow read: if isManagerOrHigher();
      allow write: if isAuthenticated(); // Sistema puede escribir logs
    }

    // ========================================
    // DENEGAR ACCESO POR DEFECTO
    // ========================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}